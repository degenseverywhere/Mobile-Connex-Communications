<div class="collection-header">
  <div class="mcx-container">
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p>{{ collection.description }}</p>
    {%- endif -%}
  </div>
</div>

{%- comment -%} Condition guide for refurbished {%- endcomment -%}
{%- if section.settings.show_condition_guide -%}
<div class="mcx-container">
  <div class="condition-guide" style="margin-top:1.5rem;">
    <div class="condition-pill"><strong>Mint</strong><span>Like new, minimal use</span></div>
    <div class="condition-pill"><strong>Good</strong><span>Light scratches, fully working</span></div>
    <div class="condition-pill"><strong>Fair</strong><span>Visible wear, 100% functional</span></div>
  </div>
</div>
{%- endif -%}

{%- comment -%} Tag / brand filters {%- endcomment -%}
{%- if collection.all_tags.size > 0 and section.settings.show_filters -%}
  <div class="mcx-container">
    <div class="filter-bar">
      <span class="filter-label">Filter:</span>
      <a href="{{ collection.url }}"
         class="filter-btn{% unless current_tags %}  active{% endunless %}">All</a>
      {%- for tag in collection.all_tags -%}
        {%- if tag contains 'Brand:' or tag == 'Apple' or tag == 'Samsung' or tag == 'OPPO'
              or tag == 'Mint' or tag == 'Good' or tag == 'Fair' -%}
          {%- assign clean_tag = tag | remove: 'Brand:' | strip -%}
          <a href="{{ collection.url }}/{{ tag | handle }}"
             class="filter-btn{% if current_tags contains tag %} active{% endif %}">
            {{ clean_tag }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

<div class="mcx-container" style="padding-bottom:4rem;">
  {%- paginate collection.products by section.settings.products_per_page -%}
    {%- if collection.products.size > 0 -%}
      <div class="product-grid" style="padding-top:1.5rem;">
        {%- for product in collection.products -%}
          {%- assign badge = '' -%}
          {%- if product.tags contains 'New' -%}{%- assign badge = 'New' -%}{%- endif -%}
          {%- if product.tags contains 'Mint' -%}{%- assign badge = 'Mint' -%}{%- endif -%}
          {%- if product.tags contains 'Good' -%}{%- assign badge = 'Good' -%}{%- endif -%}
          {%- if product.tags contains 'Fair' -%}{%- assign badge = 'Fair' -%}{%- endif -%}
          {%- render 'product-card', product: product, badge: badge -%}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div style="display:flex;justify-content:center;gap:.5rem;padding-top:3rem;">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn-outline">&larr; Previous</a>
          {%- endif -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn-outline">Next &rarr;</a>
          {%- endif -%}
        </div>
      {%- endif -%}

    {%- else -%}
      <div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 15s1.5 2 4 2 4-2 4-2"/><line x1="9" x2="9.01" y1="9" y2="9"/><line x1="15" x2="15.01" y1="9" y2="9"/></svg>
        <h3>No products here yet</h3>
        <p>Check back soon or browse our other collection.</p>
        <a href="{{ routes.root_url }}" class="btn btn-primary">Back to Home</a>
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Collection page",
  "settings": [
    { "type": "range",    "id": "products_per_page",    "label": "Products per page",  "min": 8, "max": 48, "step": 4, "default": 16 },
    { "type": "checkbox", "id": "show_filters",         "label": "Show tag filters",   "default": true },
    { "type": "checkbox", "id": "show_condition_guide", "label": "Show condition guide (for refurbished)", "default": false }
  ]
}
{% endschema %}
